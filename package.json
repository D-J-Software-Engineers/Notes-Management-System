{
  "name": "nsoma-digilib",
  "version": "1.0.0",
  "description": "Nsoma DigiLib - Digital Library for Ugandan schools",
  "keywords": [
    "education",
    "notes",
    "management",
    "uganda",
    "uneb",
    "school"
  ],
  "homepage": "https://github.com/D-J-Software-Engineers/Notes-Management-System#readme",
  "bugs": {
    "url": "https://github.com/D-J-Software-Engineers/Notes-Management-System/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/D-J-Software-Engineers/Notes-Management-System.git"
  },
  "license": "MIT",
  "author": "Agaba Derrick",
  "type": "commonjs",
  "main": "main.js",
  "bin": {
    "nsoma-digilib": "server/server.js"
  },
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "format": "prettier --write \"**/*.{js,json,md,html,css}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,html,css}\"",
    "test": "node --test server/tests/*.test.js",
    "test:ai": "node --test server/tests/ai.test.js",
    "seed": "node server/utils/seedDatabase.js",
    "electron:start": "electron .",
    "electron:build": "electron-builder --win --x64",
    "service:install": "node windows-service/service-manager.js install",
    "service:start": "node windows-service/service-manager.js start",
    "service:stop": "node windows-service/service-manager.js stop",
    "service:uninstall": "node windows-service/service-manager.js uninstall",
    "service:status": "node windows-service/service-manager.js status",
    "android:build": "cd ./client && npm run build && cd .. && npx cap sync android && npx cap build android",
    "pkg:build": "pkg . --targets node18-win-x64 --output nsoma-windows-server.exe"
  },
  "dependencies": {
    "@capacitor/android": "^5.7.8",
    "@capacitor/core": "^5.7.8",
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "format": "^0.2.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-windows": "^1.0.0-beta.8",
    "openai": "^6.33.0",
    "sequelize": "^6.35.2",
    "sqlite3": "^5.0.2",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.1.14",
    "pkg": "^5.8.1",
    "prettier": "^3.8.1",
    "proxyquire": "^2.1.3",
    "sinon": "^21.0.3"
  },
  "build": {
    "appId": "com.nsomadiglibs.app",
    "productName": "Nsoma-DigiLib",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "server/**/*",
      "client/public/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": "database.sqlite",
        "to": "database.sqlite"
      },
      {
        "from": "database.sqlite-wal",
        "to": "database.sqlite-wal"
      },
      {
        "from": "database.sqlite-shm",
        "to": "database.sqlite-shm"
      },
      {
        "from": "uploads",
        "to": "uploads"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "client/public/assets/images/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    },
    "npmRebuild": false,
    "buildDependenciesFromSource": false
  },
  "pkg": {
    "assets": [
      "client/public/**/*",
      "server/config/**/*",
      "server/controllers/**/*",
      "server/middleware/**/*",
      "server/models/**/*",
      "server/routes/**/*",
      "server/utils/**/*",
      "uploads/**/*",
      "database.sqlite",
      "database.sqlite-wal",
      "database.sqlite-shm"
    ]
  }
}
